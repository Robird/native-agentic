{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sample Packet V1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sample_packet_v1"
    },
    "sample_id": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "sample_index": {
      "type": "integer",
      "minimum": 1
    },
    "attempt_metadata": {
      "$ref": "#/definitions/attemptMetadata"
    },
    "created_at": {
      "type": "string"
    },
    "scenario": {
      "$ref": "#/definitions/scenarioSnapshot"
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "type": "string"
        },
        "generation_run_id": {
          "type": "string"
        },
        "evaluation_run_id": {
          "type": "string"
        },
        "pipeline_mode": {
          "type": "string"
        },
        "trajectory_profile": {
          "type": "string"
        },
        "trajectory_schema_version": {
          "type": "string"
        },
        "teacher_schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "feedback_protocol_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "failure_taxonomy_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "evaluation_profile": {
          "type": "string"
        },
        "evaluation_schema_version": {
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "generation_run_id",
        "evaluation_run_id",
        "pipeline_mode",
        "trajectory_profile",
        "trajectory_schema_version",
        "teacher_schema_version",
        "feedback_protocol_profile",
        "failure_taxonomy_profile",
        "evaluation_profile",
        "evaluation_schema_version"
      ]
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "teacher_agent": {
          "$ref": "#/definitions/agentContract"
        },
        "evaluator_agent": {
          "$ref": "#/definitions/agentContract"
        }
      },
      "required": [
        "teacher_agent",
        "evaluator_agent"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "teacher_analysis": {
          "type": [
            "object",
            "null"
          ]
        },
        "trajectory": {
          "type": [
            "object",
            "null"
          ]
        },
        "evaluation": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "teacher_analysis",
        "trajectory",
        "evaluation"
      ]
    },
    "repair_history": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/repairAttempt"
      }
    },
    "failure_assessment": {
      "$ref": "#/definitions/failureAssessment"
    },
    "feedback_decision": {
      "$ref": "#/definitions/feedbackDecision"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generation_parse_status": {
          "type": "string"
        },
        "teacher_parse_status": {
          "type": "string"
        },
        "evaluation_parse_status": {
          "type": "string"
        },
        "teacher_recommended_action_label": {
          "type": "string"
        },
        "chosen_action_label": {
          "type": "string"
        },
        "overall_verdict": {
          "type": "string"
        },
        "rewrite_priority": {
          "type": "string"
        },
        "feedback_rule_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "feedback_suggested_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "feedback_next_action": {
          "type": [
            "string",
            "null"
          ]
        },
        "primary_failure_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "highest_failure_severity": {
          "type": [
            "string",
            "null"
          ]
        },
        "failure_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "axis_scores": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "required": [
        "generation_parse_status",
        "teacher_parse_status",
        "evaluation_parse_status",
        "teacher_recommended_action_label",
        "chosen_action_label",
        "overall_verdict",
        "rewrite_priority",
        "feedback_rule_id",
        "feedback_suggested_status",
        "feedback_next_action",
        "primary_failure_id",
        "highest_failure_severity",
        "failure_ids",
        "axis_scores"
      ]
    },
    "quality_signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assistant_contamination_risk": {
          "type": [
            "string",
            "null"
          ]
        },
        "over_explaining_risk": {
          "type": [
            "string",
            "null"
          ]
        },
        "world_model_consistency": {
          "type": [
            "integer",
            "null"
          ]
        },
        "assistant_contamination_detected": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "assistant_contamination_risk",
        "over_explaining_risk",
        "world_model_consistency",
        "assistant_contamination_detected"
      ]
    },
    "review_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "needs_revision",
            "manual_review",
            "rejected"
          ]
        },
        "next_action": {
          "type": "string",
          "enum": [
            "approve",
            "revise_prompt_local",
            "regenerate_from_teacher",
            "manual_review",
            "reject",
            "rerun_generation"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "next_action",
        "reason"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generator_model_profile": {
          "type": "string"
        },
        "generator_model": {
          "type": "string"
        },
        "evaluator_model_profile": {
          "type": "string"
        },
        "evaluator_model": {
          "type": "string"
        },
        "generation_usage": {
          "type": [
            "object",
            "null"
          ]
        },
        "teacher_usage": {
          "type": [
            "object",
            "null"
          ]
        },
        "evaluation_usage": {
          "type": [
            "object",
            "null"
          ]
        },
        "source_refs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "generation_manifest_ref": {
              "type": "string"
            },
            "evaluation_manifest_ref": {
              "type": "string"
            },
            "teacher_request_ref": {
              "type": [
                "string",
                "null"
              ]
            },
            "teacher_raw_ref": {
              "type": [
                "string",
                "null"
              ]
            },
            "trajectory_request_ref": {
              "type": [
                "string",
                "null"
              ]
            },
            "trajectory_raw_ref": {
              "type": [
                "string",
                "null"
              ]
            },
            "evaluation_request_ref": {
              "type": [
                "string",
                "null"
              ]
            },
            "evaluation_raw_ref": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "generation_manifest_ref",
            "evaluation_manifest_ref",
            "teacher_request_ref",
            "teacher_raw_ref",
            "trajectory_request_ref",
            "trajectory_raw_ref",
            "evaluation_request_ref",
            "evaluation_raw_ref"
          ]
        }
      },
      "required": [
        "generator_model_profile",
        "generator_model",
        "evaluator_model_profile",
        "evaluator_model",
        "generation_usage",
        "teacher_usage",
        "evaluation_usage",
        "source_refs"
      ]
    }
  },
  "required": [
    "schema_version",
    "sample_id",
    "scenario_id",
    "sample_index",
    "attempt_metadata",
    "created_at",
    "scenario",
    "pipeline",
    "contracts",
    "artifacts",
    "repair_history",
    "failure_assessment",
    "feedback_decision",
    "summary",
    "quality_signals",
    "review_state",
    "provenance"
  ],
  "definitions": {
    "actionOption": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "label",
        "description"
      ]
    },
    "scenarioSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "situation": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "action_options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/actionOption"
          }
        }
      },
      "required": [
        "id",
        "name",
        "profile",
        "situation",
        "task",
        "action_options"
      ]
    },
    "attemptMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attempt_index": {
          "type": "integer",
          "minimum": 0
        },
        "attempt_kind": {
          "type": "string",
          "enum": [
            "initial",
            "repair"
          ]
        },
        "auto_repaired": {
          "type": "boolean"
        },
        "repair_origin_sample_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "attempt_index",
        "attempt_kind",
        "auto_repaired",
        "repair_origin_sample_id"
      ]
    },
    "reviewSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        },
        "next_action": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "next_action",
        "reason"
      ]
    },
    "repairAttempt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attempt_index": {
          "type": "integer",
          "minimum": 1
        },
        "next_action": {
          "type": "string",
          "enum": [
            "revise_prompt_local",
            "regenerate_from_teacher"
          ]
        },
        "repair_target": {
          "type": "string",
          "enum": [
            "trajectory_prompt",
            "teacher_stage"
          ]
        },
        "instruction_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reused_teacher_analysis": {
          "type": "boolean"
        },
        "source_review_state": {
          "$ref": "#/definitions/reviewSnapshot"
        },
        "source_primary_failure": {
          "type": [
            "string",
            "null"
          ]
        },
        "result_review_state": {
          "$ref": "#/definitions/reviewSnapshot"
        },
        "result_primary_failure": {
          "type": [
            "string",
            "null"
          ]
        },
        "generation_manifest_ref": {
          "type": "string"
        },
        "evaluation_manifest_ref": {
          "type": "string"
        }
      },
      "required": [
        "attempt_index",
        "next_action",
        "repair_target",
        "instruction_ref",
        "reused_teacher_analysis",
        "source_review_state",
        "source_primary_failure",
        "result_review_state",
        "result_primary_failure",
        "generation_manifest_ref",
        "evaluation_manifest_ref"
      ]
    },
    "failureTag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failure_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "repair_stage": {
          "type": "string",
          "enum": [
            "trajectory_prompt",
            "teacher_stage",
            "manual",
            "dataset_policy",
            "generation_rerun"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "guidance": {
          "type": "string"
        }
      },
      "required": [
        "failure_id",
        "label",
        "category",
        "severity",
        "confidence",
        "repair_stage",
        "evidence",
        "guidance"
      ]
    },
    "failureAssessment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "taxonomy_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "primary_failure_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "highest_severity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical",
            null
          ]
        },
        "failure_tags": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/failureTag"
          }
        }
      },
      "required": [
        "taxonomy_profile",
        "primary_failure_id",
        "highest_severity",
        "failure_tags"
      ]
    },
    "feedbackDecision": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protocol_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "rule_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "suggested_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "approved",
            "needs_revision",
            "manual_review",
            "rejected",
            null
          ]
        },
        "suggested_next_action": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "approve",
            "revise_prompt_local",
            "regenerate_from_teacher",
            "manual_review",
            "reject",
            "rerun_generation",
            null
          ]
        },
        "preferred_repair_stage": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "none",
            "trajectory_prompt",
            "teacher_stage",
            "manual",
            "dataset_policy",
            "generation_rerun",
            null
          ]
        },
        "urgency": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            null
          ]
        },
        "blocking": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "protocol_id",
        "rule_id",
        "suggested_status",
        "suggested_next_action",
        "preferred_repair_stage",
        "urgency",
        "blocking",
        "rationale"
      ]
    },
    "agentContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "output_schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "input_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "parse_failed",
            "skipped",
            "not_used",
            "missing"
          ]
        }
      },
      "required": [
        "input_schema_version",
        "output_schema_version",
        "input_ref",
        "status"
      ]
    }
  }
}